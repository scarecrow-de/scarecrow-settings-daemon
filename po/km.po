#: ../data/scarecrow-settings-daemon.desktop.in.in.h:1
msgid "GNOME Settings Daemon"
msgstr "бһҠбҹҒбһҳбһ·бһ“вҖӢбһҖбһ¶бһҡвҖӢбһҖбҹҶбһҺбһҸбҹӢ GNOME"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:1
msgid "Smartcard removal action"
msgstr "бһҹбһҖбһҳбҹ’бһҳбһ—бһ¶бһ–вҖӢбһҖбһ¶бһҡвҖӢбһҷбһҖ Smartcard бһ…бҹҒбһү"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:2
msgid ""
"Set this to one of \"none\", \"lock-screen\", or \"force-logout\". The "
"action will get performed when the smartcard used for log in is removed."
msgstr ""
"бһҖбҹҶбһҺбһҸбҹӢвҖӢбһңбһ¶вҖӢбһ‘бҹ… \"бһӮбҹ’бһҳбһ¶бһ“\" \"бһ…бһ¶бһҖбҹӢбһҹбҹ„вҖӢбһўбҹҒбһҖбҹ’бһҡбһ„бҹӢ\" бһ¬ \"бһ”бһ„бҹ’бһҒбҹҶвҖӢбһ…бҹҒбһү\" бҹ” бһҹбһҖбһҳбҹ’бһҳбһ—бһ¶бһ–вҖӢбһ“бһ№бһ„вҖӢбһ”бҹ’бһҡбһҸбһ·бһ”бһҸбҹ’бһҸбһ·вҖӢбһ“бҹ…вҖӢбһ–бҹҒбһӣвҖӢ "
"smartcard бһҸбҹ’бһҡбһјбһңвҖӢвҖӢбһ”бһ¶бһ“вҖӢбһ”бҹ’бһҡбһҫвҖӢбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢвҖӢбһ…бһјбһӣ бһ¬вҖӢбһҷбһҖбһ…бҹҒбһү бҹ”"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:3
msgid "Disable touchpad while typing"
msgstr "бһ”бһ·бһ‘вҖӢбһ”бһ“бҹ’бһ‘бҹҮвҖӢбһ”бҹүбҹҮвҖӢбһ–бҹҒбһӣвҖӢбһҖбҹҶбһ–бһ»бһ„вҖӢбһңбһ¶бһҷ"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:4
msgid ""
"Set this to TRUE if you have problems with accidentally hitting the touchpad "
"while typing."
msgstr "бһҖбҹҶбһҺбһҸбҹӢвҖӢбһңбһ¶вҖӢбһ‘бҹ…вҖӢбһ–бһ·бһҸвҖӢбһ”бҹ’бһҡбһҹбһ·бһ“бһ”бһҫвҖӢбһўбҹ’бһ“бһҖвҖӢбһҳбһ¶бһ“вҖӢбһ”бһүбҹ’бһ бһ¶вҖӢбһҖбһ¶бһҡвҖӢбһ”бҹүбҹҮвҖӢбһ”бһ“бҹ’бһ‘бҹҮвҖӢбһ…бһ»бһ…вҖӢбһҠбҹ„бһҷвҖӢбһ…бҹғбһҠбһ“бҹ’бһҷвҖӢбһ–бҹҒбһӣвҖӢбһҖбҹҶбһ–бһ»бһ„вҖӢбһңбһ¶бһҷ бҹ”"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:5
msgid "Enable horizontal scrolling"
msgstr "бһ”бһҫбһҖвҖӢбһҡбһҳбһјбһҡвҖӢбһ•бҹ’бһҠбҹҒбһҖ"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:6
msgid ""
"Set this to TRUE to allow horizontal scrolling by the same method selected "
"with the scroll_method key."
msgstr "бһҖбҹҶбһҺбһҸбҹӢбһңбһ¶вҖӢбһ‘бҹ…вҖӢбһ–бһ·бһҸвҖӢбһҠбһҫбһҳбҹ’бһ”бһёвҖӢбһўбһ“бһ»бһүбҹ’бһүбһ¶бһҸвҖӢбһҡбһҳбһјбһҡвҖӢбһ•бҹ’бһҠбҹҒбһҖвҖӢбһҸбһ¶бһҳвҖӢбһңбһ·бһ’бһёбһҹбһ¶бһҹбҹ’бһҸбҹ’бһҡвҖӢбһҠбһјбһ…бһӮбҹ’бһ“бһ¶вҖӢбһҠбҹӮбһӣвҖӢбһ”бһ¶бһ“вҖӢбһҮбҹ’бһҡбһҫбһҹ бһҮбһ¶бһҳбһҪбһҷвҖӢбһҹбҹ„вҖӢбһңбһ·бһ’бһёбһҹбһ¶бһҹбҹ’бһҸбҹ’бһҡвҖӢбһҡбһҳбһјбһҡ бҹ”"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:7
msgid "Select the touchpad scroll method"
msgstr "бһҮбҹ’бһҡбһҫбһҹвҖӢбһңбһ·бһ’бһёбһҹбһ¶бһҹбҹ’бһҸбҹ’бһҡвҖӢбһҡбһҳбһјбһҡвҖӢбһ”бһ“бҹ’бһ‘бҹҮвҖӢбһ”бҹүбҹҮ"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:8
msgid ""
"Select the touchpad scroll method. Supported values are: \"disabled\", "
"\"edge-scrolling\", \"two-finger-scrolling\"."
msgstr "бһҮбҹ’бһҡбһҫбһҹвҖӢбһңбһ·бһ’бһёбһҹбһ¶бһҹбҹ’бһҸбҹ’бһҡвҖӢбһҡбһҳбһјбһҡвҖӢбһ”бһ“бҹ’бһ‘бҹҮвҖӢбһ”бҹүбҹҮ бҹ” бһҸбһҳбҹ’бһӣбҹғвҖӢбһӮбһ¶бҹҶбһ‘бҹ’бһҡвҖӢбһӮбһә бҹ– \"бһ”бһ·бһ‘\" \"бһҡбһҳбһјбһҡвҖӢбһӮбҹӮбһҳ\" \"бһҡбһҳбһјбһҡвҖӢбһҳбҹ’бһҡбһ¶бһҳвҖӢбһ–бһёбһҡ\" бҹ”"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:9
msgid "Enable mouse clicks with touchpad"
msgstr "бһ”бһҫбһҖвҖӢбһҖбһ¶бһҡвҖӢбһ…бһ»бһ…вҖӢбһҖбһҺбҹ’бһҠбһ»бһҡвҖӢбһҮбһ¶бһҳбһҪбһҷвҖӢбһ”бһ“бҹ’бһ‘бҹҮвҖӢбһ”бҹүбҹҮ"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:10
msgid ""
"Set this to TRUE to be able to send mouse clicks by tapping on the touchpad."
msgstr "бһҖбҹҶбһҺбһҸбҹӢвҖӢбһңбһ¶вҖӢбһ‘бҹ…вҖӢбһ–бһ·бһҸвҖӢбһҠбһҫбһҳбҹ’бһ”бһёвҖӢбһўбһ¶бһ…вҖӢбһ•бҹ’бһүбһҫвҖӢбһҖбһ¶бһҡвҖӢбһ…бһ»бһ…вҖӢбһҖбһҺбҹ’бһҠбһ»бһҡвҖӢбһ”бһ¶бһ“вҖӢбһҠбҹ„бһҷвҖӢбһӮбҹ’бһҡбһ¶бһ“бҹӢбһҸбҹӮвҖӢбһӮбҹ„бҹҮвҖӢбһ“бҹ…вҖӢбһӣбһҫвҖӢбһ”бһ“бҹ’бһ‘бҹҮвҖӢбһ”бҹүбҹҮ бҹ”"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:11
msgid "Enable touchpad"
msgstr "бһ”бһҫбһҖвҖӢбһ”бһ“бҹ’бһ‘бҹҮвҖӢбһ”бҹүбҹҮ"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:12
msgid "Set this to TRUE to enable all touchpads."
msgstr "бһҖбҹҶбһҺбһҸбҹӢвҖӢбһңбһ¶вҖӢвҖӢбһ–бһ·бһҸ вҖӢбһҠбһҫбһҳбҹ’бһ”бһёвҖӢбһ”бһҫбһҖвҖӢбһ”бһ“бҹ’бһ‘бҹҮвҖӢбһ”бҹүбҹҮвҖӢбһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢ бҹ”"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:13
msgid ""
"Highlights the current location of the pointer when the Control key is "
"pressed and released."
msgstr "бһҡбҹҶбһӣбҹҒбһ…вҖӢбһ‘бһёбһҸбһ¶бҹҶбһ„вҖӢбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“вҖӢбһ“бҹғвҖӢбһ–бҹ’бһҡбһҪбһүвҖӢбһ…бһ„бҹ’бһўбһ»бһӣвҖӢбһ“бҹ…вҖӢбһ–бҹҒбһӣвҖӢбһҠбҹӮбһӣвҖӢбһ”бһ¶бһ“вҖӢбһ…бһ»бһ… бһ“бһ·бһ„вҖӢбһ”бҹ’бһҡбһӣбҹӮбһ„вҖӢбһӮбҹ’бһҡбһ¶бһ”бҹӢбһ…бһ»бһ…вҖӢбһ”бһүбҹ’бһҮбһ¶ (Ctrl) бҹ”"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:14
msgid "Double click time"
msgstr "бһ–бҹҒбһӣбһңбҹҒбһӣбһ¶вҖӢбһ…бһ»бһ…вҖӢбһ‘бҹ’бһңбҹҒбһҠбһ„"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:15
msgid "Length of a double click in milliseconds."
msgstr "бһ”бҹ’бһҡбһңбҹӮбһ„вҖӢбһ…бһ»бһ…вҖӢбһ‘бҹ’бһңбҹҒбһҠбһ„вҖӢбһӮбһ·бһҸбһҮбһ¶вҖӢбһҳбһ·бһӣбҹ’бһӣбһёвҖӢбһңбһ·бһ“бһ¶бһ‘бһё бҹ”"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:16
msgid "Drag threshold"
msgstr "бһўбһјбһҹвҖӢбһҖбһҳбҹ’бһҡбһ·бһҸвҖӢбһ–бһ“бҹ’бһӣбһә"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:17
msgid "Distance before a drag is started."
msgstr "бһ…бһҳбҹ’бһ„бһ¶бһҷвҖӢбһҳбһ»бһ“вҖӢбһ–бҹҒбһӣвҖӢбһ…бһ¶бһ”бҹӢбһ•бҹ’бһҠбһҫбһҳвҖӢбһўбһјбһҹ"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:18
msgid "Middle button emulation"
msgstr "бһҖбһ¶бһҡвҖӢбһҸбҹ’бһҡбһ¶бһ”бҹӢбһҸбһ¶бһҳвҖӢбһ”бҹҠбһјбһҸбһ»бһ„вҖӢбһҖбһҺбҹ’бһҠбһ¶бһӣ"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:19
msgid ""
"Enables middle mouse button emulation through simultaneous left and right "
"button click."
msgstr "бһ”бһҫбһҖвҖӢбһҖбһ¶бһҡвҖӢбһҸбҹ’бһҡбһ¶бһ”бҹӢбһҸбһ¶бһҳвҖӢбһ”бҹҠбһјбһҸбһ»бһ„вҖӢбһҖбһҺбҹ’бһҠбһ»бһҡвҖӢбһҖбһҺбҹ’бһҠбһ¶бһӣвҖӢбһҠбҹҶбһҺбһ¶бһӣбһӮбҹ’бһ“бһ¶вҖӢбһҮбһ¶бһҳбһҪбһҷвҖӢбһҖбһ¶бһҡвҖӢбһ…бһ»бһ…вҖӢбһ”бҹҠбһјбһҸбһ»бһ„вҖӢбһҶбҹ’бһңбҹҒбһ„ бһ“бһ·бһ„вҖӢбһҹбҹ’бһҠбһ¶бҹҶвҖӢбһҠбҹӮбһҡ бҹ”"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:20
msgid "Whether the tablet's orientation is locked, or rotated automatically."
msgstr "бһҗбһ¶вҖӢбһҸбһҫвҖӢбһ‘бһ·бһҹвҖӢбһҡбһ”бһҹбҹӢ tablet бһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһ…бһ¶бһҖбҹӢбһҹбҹ„ бһ¬вҖӢбһ”бһ„бҹ’бһңбһ·бһӣвҖӢбһҠбҹ„бһҷвҖӢбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ· бҹ”"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:21
msgid "Device hotplug custom command"
msgstr "бһ–бһ¶бһҖбҹ’бһҷвҖӢбһ”бһүбҹ’бһҮбһ¶вҖӢбһ•бҹ’бһ‘бһ¶бһӣбҹӢбһҒбҹ’бһӣбһҪбһ“вҖӢбһ§бһ”бһҖбһҡбһҺбҹҚвҖӢбһҠбҹ„бһҸ"

#: ../data/io.github.scarecrow.settings-daemon.peripherals.gschema.xml.in.in.h:22
msgid "Command to be run when a device is added or removed."
msgstr "бһ–бһ¶бһҖбҹ’бһҷвҖӢбһ”бһүбҹ’бһҮбһ¶вҖӢбһҠбҹӮбһӣвҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһҠбҹҶбһҺбһҫбһҡбһҖбһ¶бһҡвҖӢбһ–бҹҒбһӣвҖӢбһ§бһ”бһҖбһҡбһҺбҹҚвҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһ”бһ“бҹ’бһҗбҹӮбһҳ бһ¬вҖӢбһҷбһҖбһ…бҹҒбһү бҹ”"

